# ============================================================
# Among Liars — environment variables
# ------------------------------------------------------------
# Local dev : copy this file to `.env.local` (gitignored) and fill in.
# Production (Netlify) : set each variable in
#   Site settings -> Build & deploy -> Environment -> Environment variables
# Redeploy after editing them (Netlify doesn't hot-swap env vars).
# ============================================================

# PlayroomKit -- https://joinplayroom.com -> your project -> gameId
# REQUIRED. The app throws at boot if this is missing (on purpose -- a
# silent fallback would make rooms live on a shared/example quota).
REACT_APP_PLAYROOM_GAME_ID=

# Supabase -- https://supabase.com -> your project -> Settings -> API
# Both values are safe to expose client-side (the anon key is designed
# for that; Row Level Security in Supabase is what actually protects
# your tables -- make sure RLS policies are enabled before going live).
# Leaving these empty disables the optional auth/XP features and the
# app runs in guest-only mode.
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
