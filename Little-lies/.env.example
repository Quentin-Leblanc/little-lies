# ============================================================
# Among Liars — environment variables
# Copy this file to `.env.local` (gitignored) for local dev,
# and duplicate these vars in your Netlify site settings for prod.
# ============================================================

# PlayroomKit — https://joinplayroom.com → your project → gameId
# Leaving this blank falls back to the bundled example gameId (shared
# quota with other projects — fine for playing around, never for prod).
REACT_APP_PLAYROOM_GAME_ID=

# Supabase — https://supabase.com → Settings → API
# Both values are safe to expose client-side (the anon key is designed
# for that; row-level security in Supabase protects your data).
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
