# Cloudflare Pages headers config (also compatible with Netlify syntax).
# Mirrors netlify.toml so we can serve the exact same policy from either
# host. Each block starts with a path pattern, followed by indented
# "Header: value" lines. Empty lines end the block.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: microphone=(), camera=(), geolocation=()
  # CSP: 'unsafe-inline' for styles is required by react-scripts runtime CSS-in-JS
  # and inline <style> from index.html. 'wasm-unsafe-eval' is needed by
  # @react-three + @mediapipe. Data: URIs are allowed for inline SVG avatars.
  # connect-src covers PlayroomKit, Supabase, and Google Fonts file host.
  # script-src 'unsafe-inline' + 'unsafe-eval' required by PlayroomKit's
  # sandboxed iframes (inline scripts + eval in its runtime). blob: in
  # connect-src: GLTFLoader fetches its ObjectURL textures via XHR.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://joinplayroom.com https://*.joinplayroom.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; media-src 'self'; connect-src 'self' blob: https://*.supabase.co wss://*.supabase.co https://joinplayroom.com https://*.joinplayroom.com wss://*.joinplayroom.com; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# index.html: always revalidate. Without this, Firefox can serve a stale
# copy that references vanished hashed bundles (white page until hard refresh).
/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Hashed assets: cache forever (react-scripts embeds content hash in filenames)
/static/*
  Cache-Control: public, max-age=31536000, immutable

# 3D models: short cache so GLB updates propagate within a day
/models/*
  Cache-Control: public, max-age=86400
